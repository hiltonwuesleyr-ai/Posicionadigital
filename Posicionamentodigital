    background: linear-gradient(180deg, transparent, #2563EB 12%, #2563EB 88%, transparent);
  }

  ::selection{ background: rgba(37,99,235,0.22); }

  .noscroll-x{ overflow-x:clip; }

  /* focus visibility */
  a:focus-visible, button:focus-visible{ outline: 2px solid #2563EB; outline-offset: 3px; border-radius: 6px; }
</style>
