  html.dark .btn-ghost:hover{ border-color: rgba(248,250,252,0.32); background: rgba(248,250,252,0.05); }

  /* Accordion */
  .accordion-content{ max-height:0; overflow:hidden; transition: max-height .5s cubic-bezier(.16,1,.3,1); }
  .accordion-item.open .accordion-content{ max-height: 320px; }
  .accordion-item.open .chevron{ transform: rotate(45deg); }
