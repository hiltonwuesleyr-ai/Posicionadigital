  }
  html.dark body{ background:#080D1A; color:#F1F5F9; }

  /* ---------- Reveal on scroll ---------- */
  .reveal{ opacity:0; transform: translateY(28px); transition: opacity .8s cubic-bezier(.16,1,.3,1), transform .8s cubic-bezier(.16,1,.3,1); }
  .reveal.in{ opacity:1; transform: translateY(0); }
  .reveal-delay-1{ transition-delay: .08s; }
  .reveal-delay-2{ transition-delay: .16s; }
  .reveal-delay-3{ transition-delay: .24s; }
  .reveal-delay-4{ transition-delay: .32s; }

  @media (prefers-reduced-motion: reduce){
    .reveal{ opacity:1 !important; transform:none !important; transition:none !important; }
    *{ animation: none !important; }
  }

  /* ---------- Grain / dot grid backdrop ---------- */
  .dot-grid{
    background-image: radial-gradient(circle, rgba(100,116,139,0.28) 1px, transparent 1px);
    background-size: 26px 26px;
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 40%, transparent 100%);
            mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 40%, transparent 100%);
  }

  /* ---------- Radar signature motif ---------- */
  .radar-ring{
    position:absolute; border-radius:9999px; border:1px solid rgba(37,99,235,0.35);
    animation: radarPulse 3.6s cubic-bezier(.22,.61,.36,1) infinite;
  }
  .radar-ring.r2{ animation-delay: 1.2s; }
  .radar-ring.r3{ animation-delay: 2.4s; }
  @keyframes radarPulse{
    0%{ transform: scale(0.55); opacity: .55; }
    80%{ opacity: 0; }
    100%{ transform: scale(1.25); opacity: 0; }
  }
  .signal-badge{
    animation: floatBadge 5s ease-in-out infinite;
  }
  .signal-badge.b2{ animation-delay: .8s; }
  .signal-badge.b3{ animation-delay: 1.6s; }
  @keyframes floatBadge{
    0%,100%{ transform: translateY(0px); }
    50%{ transform: translateY(-9px); }
  }

  .glass{
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
    border: 1px solid rgba(15,23,42,0.06);
  }
  html.dark .glass{
    background: rgba(15,23,42,0.62);
    border: 1px solid rgba(255,255,255,0.08);
  }

  .text-gradient{
    background: linear-gradient(100deg, #0F172A 20%, #2563EB 55%, #0F172A 85%);
    -webkit-background-clip: text; background-clip:text; color:transparent;
    background-size: 200% auto;
  }
  html.dark .text-gradient{
    background: linear-gradient(100deg, #F8FAFC 20%, #60A5FA 55%, #F8FAFC 85%);
    -webkit-background-clip: text; background-clip:text; color:transparent;
  }

  .card-hover{ transition: transform .45s cubic-bezier(.16,1,.3,1), box-shadow .45s cubic-bezier(.16,1,.3,1), border-color .3s ease; }
  .card-hover:hover{ transform: translateY(-6px); }

  .btn-primary{
    background:#0F172A; color:#fff;
    transition: transform .35s cubic-bezier(.16,1,.3,1), box-shadow .35s ease, background .3s ease;
  }
  .btn-primary:hover{ transform: translateY(-2px); box-shadow: 0 16px 40px -12px rgba(15,23,42,0.45); }
  html.dark .btn-primary{ background:#F8FAFC; color:#0F172A; }
  html.dark .btn-primary:hover{ box-shadow: 0 16px 40px -12px rgba(248,250,252,0.25); }

  .btn-cta{
    background: linear-gradient(135deg, #10B981, #059669);
    color:#fff;
    transition: transform .35s cubic-bezier(.16,1,.3,1), box-shadow .35s ease;
