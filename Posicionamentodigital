  }
  .btn-cta:hover{ transform: translateY(-2px); box-shadow: 0 20px 40px -12px rgba(16,185,129,0.6); }

  .btn-ghost{
    border:1px solid rgba(15,23,42,0.14); color:#0F172A;
    transition: border-color .3s ease, background .3s ease;
  }
  .btn-ghost:hover{ border-color: rgba(15,23,42,0.32); background: rgba(15,23,42,0.03); }
